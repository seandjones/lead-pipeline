# =============================================================================
# n8n Authentication
# =============================================================================
N8N_USER=admin
N8N_PASSWORD=changeme_strong_password        # Use a strong password — n8n is exposed to the internet

# =============================================================================
# Domain
# =============================================================================
DOMAIN=leads.yourdomain.com                  # Your VPS domain or IP. Must point to this server before running certbot.

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme_db_password       # Only accessible inside Docker network, but still use a strong password

# =============================================================================
# Webhook Security
# =============================================================================
WEBHOOK_SECRET=changeme_webhook_secret       # Shared secret between Apify and n8n. Generate with: openssl rand -hex 32

# =============================================================================
# Apify
# =============================================================================
APIFY_API_TOKEN=                             # https://console.apify.com/account/integrations → "Personal API tokens"

# =============================================================================
# Airtable
# =============================================================================
AIRTABLE_API_KEY=                            # https://airtable.com/create/tokens — create a Personal Access Token with data.records:write scope
AIRTABLE_BASE_ID=                            # Open your base in browser: airtable.com/{BASE_ID}/tbl... — copy the appXXXXXXXXXXXXXX portion
AIRTABLE_TABLE_NAME=Leads                    # Must exactly match the table name in your Airtable base

# =============================================================================
# Hunter.io
# =============================================================================
HUNTER_API_KEY=                              # https://hunter.io/api-keys — free tier gives 25 searches/month, Starter gives 500

# =============================================================================
# Apollo.io
# =============================================================================
APOLLO_API_KEY=                           # https://developer.apollo.io — Settings → Integrations → API Keys. Basic plan required for mobile phone export.

# =============================================================================
# Anthropic Claude API
# =============================================================================
ANTHROPIC_API_KEY=                           # https://console.anthropic.com/settings/keys

# =============================================================================
# HubSpot CRM
# =============================================================================
HUBSPOT_API_KEY=                             # HubSpot → Settings → Integrations → Private Apps → Create app with CRM read/write scopes

# =============================================================================
# Slack Notifications (optional)
# =============================================================================
SLACK_WEBHOOK_URL=                           # Slack → Your App → Incoming Webhooks → Add New Webhook. Leave blank to disable Slack alerts.

# =============================================================================
# Scraping Targets — Service Business Vertical
# =============================================================================
TARGET_CITIES=Denver CO,Aurora CO,Lakewood CO,Arvada CO,Westminster CO   # Comma-separated. Used in Apify input generation.
TARGET_VERTICALS=HVAC,plumbing,roofing                                    # Comma-separated. Used in Apify input generation.

# =============================================================================
# Real Estate Agents Vertical
# =============================================================================
# Airtable — separate base from the service business vertical
AIRTABLE_BASE_ID_RE=                         # New Airtable base for RE (appXXXXXXXXXXXXXX from URL)
AIRTABLE_TABLE_AGENTS=Agents                 # Must match table name in RE base
AIRTABLE_TABLE_RE_LEADS=RE_Leads             # Must match table name in RE base

# Target cities for RE scraping (typically affluent suburbs with high agent density)
TARGET_CITIES_RE=Scottsdale AZ,Paradise Valley AZ,Arcadia AZ             # Comma-separated. Used in generate_re_apify_inputs.py.

# Inquiry email alias — used as the "from" address in contact form submissions.
# Set up inbound email parsing (Mailgun/Postmark/SendGrid) to POST replies to:
#   https://${DOMAIN}/webhook/re-reply-webhook
INQUIRY_EMAIL_ALIAS=inquiry@yourdomain.com   # Must be a real inbox you control

# Twilio — for SMS outreach to slow-responder agents (Workflow C)
TWILIO_ACCOUNT_SID=                          # https://console.twilio.com → Account Info
TWILIO_AUTH_TOKEN=                           # https://console.twilio.com → Account Info
TWILIO_FROM_NUMBER=                          # Your Twilio phone number, e.g. +12025551234

# SendGrid — for email outreach to slow-responder agents (Workflow C fallback)
SENDGRID_API_KEY=                            # https://app.sendgrid.com/settings/api_keys

# HubSpot custom contact properties to create before activating Workflow E:
#   ai_automation_score   (Number)
#   automation_pain_signals (Multi-line text)
#   lead_summary          (Multi-line text)
#   google_rating         (Number)
#   review_count          (Number)
#   response_time_minutes (Number)
#   has_live_chat         (Single-line text)
