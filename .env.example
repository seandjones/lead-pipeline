# =============================================================================
# n8n Authentication
# =============================================================================
N8N_USER=admin
N8N_PASSWORD=changeme_strong_password        # Use a strong password — n8n is exposed to the internet

# =============================================================================
# Domain
# =============================================================================
DOMAIN=leads.yourdomain.com                  # Your VPS domain or IP. Must point to this server before running certbot.

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=changeme_db_password       # Only accessible inside Docker network, but still use a strong password

# =============================================================================
# Webhook Security
# =============================================================================
WEBHOOK_SECRET=changeme_webhook_secret       # Shared secret between Apify and n8n. Generate with: openssl rand -hex 32

# =============================================================================
# Apify
# =============================================================================
APIFY_API_TOKEN=                             # https://console.apify.com/account/integrations → "Personal API tokens"

# =============================================================================
# Airtable
# =============================================================================
AIRTABLE_API_KEY=                            # https://airtable.com/create/tokens — create a Personal Access Token with data.records:write scope
AIRTABLE_BASE_ID=                            # Open your base in browser: airtable.com/{BASE_ID}/tbl... — copy the appXXXXXXXXXXXXXX portion
AIRTABLE_TABLE_NAME=Leads                    # Must exactly match the table name in your Airtable base

# =============================================================================
# Hunter.io
# =============================================================================
HUNTER_API_KEY=                              # https://hunter.io/api-keys — free tier gives 25 searches/month, Starter gives 500

# =============================================================================
# Anthropic Claude API
# =============================================================================
ANTHROPIC_API_KEY=                           # https://console.anthropic.com/settings/keys

# =============================================================================
# HubSpot CRM
# =============================================================================
HUBSPOT_API_KEY=                             # HubSpot → Settings → Integrations → Private Apps → Create app with CRM read/write scopes

# =============================================================================
# Slack Notifications (optional)
# =============================================================================
SLACK_WEBHOOK_URL=                           # Slack → Your App → Incoming Webhooks → Add New Webhook. Leave blank to disable Slack alerts.

# =============================================================================
# Scraping Targets
# =============================================================================
TARGET_CITIES=Denver CO,Aurora CO,Lakewood CO,Arvada CO,Westminster CO   # Comma-separated. Used in Apify input generation.
TARGET_VERTICALS=HVAC,plumbing,roofing                                    # Comma-separated. Used in Apify input generation.
