{
  "name": "RE Workflow A — Agent Ingest",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "re-apify-webhook",
        "options": { "rawBody": true }
      },
      "id": "re_a_webhook",
      "name": "Webhook — RE Apify POST",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [-2400, 200],
      "webhookId": "re-apify-ingest-webhook"
    },
    {
      "parameters": {
        "jsCode": "let body = $input.item.json.body || $input.item.json;\nif (typeof body === 'string') {\n  try { body = JSON.parse(body); } catch(e) { throw new Error('Could not parse body as JSON'); }\n}\n\nif (body.eventType !== 'ACTOR.RUN.SUCCEEDED') {\n  console.log(`Ignoring event type: ${body.eventType}`);\n  return [];\n}\n\nconst datasetId = body.resource?.defaultDatasetId;\nconst apifyRunId = body.resource?.id;\n\nif (!datasetId) throw new Error('No defaultDatasetId in Apify webhook payload');\n\nreturn [{ json: { datasetId, apifyRunId } }];"
      },
      "id": "re_a_extract_dataset",
      "name": "Extract Dataset ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-2176, 200]
    },
    {
      "parameters": {
        "url": "=https://api.apify.com/v2/datasets/{{ $json.datasetId }}/items",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "format", "value": "json" },
            { "name": "clean", "value": "true" },
            { "name": "limit", "value": "1000" },
            { "name": "offset", "value": "0" }
          ]
        },
        "options": {}
      },
      "id": "re_a_fetch_dataset",
      "name": "Fetch Apify Dataset",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [-1952, 200],
      "credentials": {
        "httpHeaderAuth": { "id": "sIaw3KXseHDfgVDj", "name": "Header Auth account 2" }
      }
    },
    {
      "parameters": {
        "jsCode": "const apifyRunId = $('Extract Dataset ID').first().json.apifyRunId;\nconst records = [];\n\nfor (const input of $input.all()) {\n  const json = input.json;\n  if (Array.isArray(json)) records.push(...json);\n  else if (Array.isArray(json.data)) records.push(...json.data);\n  else if (Array.isArray(json.items)) records.push(...json.items);\n  else records.push(json);\n}\n\nreturn records.map(record => ({ json: { ...record, apifyRunId } }));"
      },
      "id": "re_a_split_items",
      "name": "Split Into Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1728, 200]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\n\nif (item.permanentlyClosed || item.temporarilyClosed) return null;\nif (!item.phone && !item.website) return null;\n\nconst phone = item.phone ? item.phone.replace(/[^\\d+\\-() ]/g, '').trim() : null;\n\nlet domain = null;\nif (item.website) {\n  try {\n    const url = new URL(item.website.startsWith('http') ? item.website : 'https://' + item.website);\n    domain = url.hostname.replace(/^www\\./, '').toLowerCase();\n  } catch(e) { domain = null; }\n}\n\nlet city = null, state = null, zip_code = null;\nif (item.address) {\n  const parts = item.address.split(',');\n  if (parts.length >= 2) {\n    city = parts[parts.length - 2]?.trim() || null;\n    const stateZip = parts[parts.length - 1]?.trim().split(' ') || [];\n    state = stateZip[0] || null;\n    zip_code = stateZip[1] || null;\n  }\n}\n\nreturn {\n  json: {\n    agent_name: item.title || item.name || null,\n    agency_name: item.subtitle || null,\n    website: item.website || null,\n    domain,\n    phone,\n    address: item.address || null,\n    city,\n    state,\n    zip_code,\n    google_rating: item.totalScore || null,\n    review_count: item.reviewsCount || 0,\n    source_query: item.searchString || null,\n    has_live_chat: false,\n    contact_form_found: false,\n    status: 'Raw',\n    date_added: new Date().toISOString().split('T')[0],\n    apify_run_id: item.apifyRunId || null\n  }\n};"
      },
      "id": "re_a_validate_clean",
      "name": "Validate & Clean Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1504, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict", "version": 1 },
          "conditions": [{
            "leftValue": "={{ $json.agent_name }}",
            "rightValue": "",
            "operator": { "type": "string", "operation": "notEmpty" }
          }],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "re_a_filter_name",
      "name": "Filter — Has Agent Name",
