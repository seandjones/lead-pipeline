        "jsCode": "const r = $('Validate & Clean Record').item.json;\n\nreturn {\n  json: {\n    airtable_body: {\n      fields: {\n        agent_name: r.agent_name || '',\n        agency_name: r.agency_name || '',\n        website: r.website || '',\n        domain: r.domain || '',\n        phone: r.phone || '',\n        address: r.address || '',\n        city: r.city || '',\n        state: r.state || '',\n        zip_code: r.zip_code || '',\n        google_rating: r.google_rating || null,\n        review_count: r.review_count || 0,\n        source_query: r.source_query || '',\n        has_live_chat: false,\n        contact_form_found: false,\n        outreach_triggered: false,\n        status: 'Raw',\n        date_added: r.date_added || ''\n      }\n    }\n  }\n};"
      },
