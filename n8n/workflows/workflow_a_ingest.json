    {
      "parameters": {
        "jsCode": "// n8n already split the array from the HTTP Request response into individual items.\n// Each execution of this node receives one record — just attach the run ID and pass through.\nconst apifyRunId = $('Extract Dataset ID').first().json.apifyRunId;\n\nconst records = [];\n\nfor (const input of $input.all()) {\n  const json = input.json;\n\n  if (Array.isArray(json)) {\n    records.push(...json);\n  } else if (Array.isArray(json.data)) {\n    records.push(...json.data);\n  } else if (Array.isArray(json.items)) {\n    records.push(...json.items);\n  } else {\n    records.push(json);\n  }\n}\n\nreturn records.map(record => ({\n  json: {\n    ...record,\n    apifyRunId\n  }\n}));"
      },
      "id": "8598bf78-868e-4517-aa16-919635cde554",
      "name": "Split Into Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1744,
        208
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\n\n// Skip closed businesses\nif (item.permanentlyClosed || item.temporarilyClosed) {\n  return null;\n}\n\n// Skip if no phone AND no website\nif (!item.phone && !item.website) {\n  return null;\n}\n\nconst phone = item.phone ? item.phone.replace(/[^\\d+\\-() ]/g, '').trim() : null;\n\nlet domain = null;\nif (item.website) {\n  try {\n    const url = new URL(item.website.startsWith('http') ? item.website : 'https://' + item.website);\n    domain = url.hostname.replace(/^www\\./, '').toLowerCase();\n  } catch (e) {\n    domain = null;\n  }\n}\n\nlet city = null;\nlet state = null;\n\nif (item.address) {\n  const parts = item.address.split(',');\n  if (parts.length >= 2) {\n    city = parts[parts.length - 2]?.trim() || null;\n    const stateZip = parts[parts.length - 1]?.trim().split(' ') || [];\n    state = stateZip[0] || null;\n  }\n}\n\nconst has_website = !!item.website;\n\nreturn {\n  json: {\n    business_name: item.title || item.name || null,\n    website: item.website || null,\n    domain,\n    phone,\n    address: item.address || null,\n    city,\n    state,\n    google_rating: item.totalScore || null,\n    review_count: item.reviewsCount || 0,\n    category: item.categoryName || (item.categories && item.categories[0]) || null,\n    has_website,\n    source: 'Maps',\n    source_query: item.searchString || null,\n    status: 'Raw',\n    website_fetch_status: has_website ? 'Pending' : 'No Website',\n    date_added: new Date().toISOString().split('T')[0],\n    apify_run_id: item.apifyRunId || null\n  }\n};"
      },
