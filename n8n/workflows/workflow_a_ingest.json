    {
      "parameters": {
        "jsCode": "// Body parsing — no secret check here, Webhook node handles that\nlet body = $input.item.json.body || $input.item.json;\nif (typeof body === 'string') {\n  try { body = JSON.parse(body); } catch(e) { throw new Error('Could not parse body as JSON'); }\n}\n\nif (body.eventType !== 'ACTOR.RUN.SUCCEEDED') {\n  console.log(`Ignoring event type: ${body.eventType}`);\n  return [];\n}\n\nconst datasetId = body.resource?.defaultDatasetId;\nconst apifyRunId = body.resource?.id;\n\nif (!datasetId) {\n  throw new Error('No defaultDatasetId in Apify webhook payload');\n}\n\nreturn [{ json: { datasetId, apifyRunId } }];"
      },
