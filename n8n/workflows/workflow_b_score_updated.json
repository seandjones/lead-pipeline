        "jsCode": "// This node runs once per item — aggregate node would be needed for a true\n// per-batch Slack message. For now we suppress all but the last item using\n// n8n's item index to avoid 25 pings for 25 records.\n// A cleaner solution is to add a Summarize node before this.\nconst slackUrl = $env.SLACK_WEBHOOK_URL;\nif (!slackUrl) return [{ json: { skipped: true } }];\nreturn [{ json: { slackUrl, slackBody: { text: '📊 *Workflow B — Record Scored*\\nAI scoring run in progress. Check Airtable Scored records for updated ai_score values.' } } }];"
