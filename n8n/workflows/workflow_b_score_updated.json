    {
      "parameters": {
        "jsCode": "// Try fetching with www. prefix if the original URL omitted it, or vice-versa.\n// This catches sites that only respond on one canonical form.\nconst record = $input.item.json;\nlet altUrl = record.website || '';\ntry {\n  const u = new URL(altUrl);\n  if (u.hostname.startsWith('www.')) {\n    u.hostname = u.hostname.replace(/^www\\./, '');\n  } else {\n    u.hostname = 'www.' + u.hostname;\n  }\n  altUrl = u.toString();\n} catch(e) {}\nreturn [{ json: { ...record, alt_website: altUrl } }];"
      },
